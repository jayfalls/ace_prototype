# ACE API Service Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# Database Configuration
# =============================================================================
# Either provide DATABASE_URL directly OR all POSTGRES_* variables

# Full database connection URL (alternative to individual POSTGRES_* variables)
# DATABASE_URL=postgres://user:password@host:port/dbname?sslmode=disable

# Individual PostgreSQL connection parameters (used if DATABASE_URL is not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=ace
POSTGRES_SSLMODE=disable

# Database connection pool settings (optional, has sensible defaults)
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=5
DATABASE_MAX_CONN_LIFETIME=3600
DATABASE_MAX_CONN_IDLE_TIME=1800

# =============================================================================
# API Server Configuration
# =============================================================================
# API server binding host (optional, default: 0.0.0.0)
API_HOST=0.0.0.0

# API server port (required)
API_PORT=8080

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins (required)
# For development, you can use http://localhost:5173 (SvelteKit default)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level: debug, info, warn, error (optional, default: info)
LOG_LEVEL=info

# =============================================================================
# JWT Authentication Configuration
# =============================================================================
# JWT secret key (required, must be at least 32 characters)
# Generate a secure random string for production
JWT_SECRET=your-very-long-secret-key-here-min-32-chars

# JWT token expiration time in hours (optional, default: 24)
JWT_EXPIRATION_HOURS=24
