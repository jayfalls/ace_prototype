# Container Orchestrator
# Options: docker, podman
CONTAINER_ORCHESTRATOR=docker

# Environment
# Options: dev, prod
ENVIRONMENT=dev

# PostgreSQL Database
POSTGRES_HOST=ace_db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ace
POSTGRES_SSLMODE=disable

# NATS Messaging Broker
NATS_URL=nats://ace_broker:4222

# Frontend
VITE_API_URL=http://localhost:8080

# =============================================================================
# API Server Configuration
# =============================================================================
# API server binding host (optional, default: 0.0.0.0)
API_HOST=0.0.0.0

# API server port (required)
API_PORT=8080

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins (required)
# For development, you can use http://localhost:5173 (SvelteKit default)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level: debug, info, warn, error (optional, default: info)
LOG_LEVEL=info

# =============================================================================
# JWT Authentication Configuration
# =============================================================================
# JWT secret key (required, must be at least 32 characters)
# Generate a secure random string for production
JWT_SECRET=your-very-long-secret-key-here-min-32-chars

# JWT token expiration time in hours (optional, default: 24)
JWT_EXPIRATION_HOURS=24

# =============================================================================
# Telemetry / Observability Configuration
# =============================================================================
# Note: Uses the same ENVIRONMENT variable as above (dev or prod)

# OTLP endpoint for traces/metrics (required)
# Example: otel-collector:4317 (gRPC) or otel-collector:4318 (HTTP)
OTLP_ENDPOINT=localhost:4317

# =============================================================================
# Container Service Ports (Optional - defaults shown)
# =============================================================================
# Frontend port
FE_PORT=5173

# PostgreSQL port
POSTGRES_PORT=5432

# NATS port
NATS_PORT=4222

# =============================================================================
# Observability Stack Ports (Optional - defaults shown)
# =============================================================================
# Prometheus metrics UI
PROMETHEUS_PORT=9090

# Grafana UI
GRAFANA_PORT=3000

# Loki log aggregation
LOKI_PORT=3100

# Tempo trace storage (OTLP gRPC)
TEMPO_OTLP_GRPC_PORT=4316
# Tempo trace storage (OTLP HTTP)
TEMPO_OTLP_HTTP_PORT=4315
# Tempo health/readiness
TEMPO_HEALTH_PORT=4314

# OTel Collector OTLP gRPC (traces/metrics from services)
OTEL_COLLECTOR_OTLP_GRPC_PORT=4317
# OTel Collector OTLP HTTP (traces/metrics from services)
OTEL_COLLECTOR_OTLP_HTTP_PORT=4318
# OTel Collector Prometheus metrics (for Prometheus to scrape)
OTEL_COLLECTOR_PROMETHEUS_PORT=8889
# OTel Collector health check
OTEL_COLLECTOR_HEALTH_PORT=8888
