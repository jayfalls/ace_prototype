{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "mcp": {
    "context-mode": {
      "type": "local",
      "command": ["npx", "-y", "context-mode"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
